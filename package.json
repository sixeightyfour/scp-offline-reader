{
  "name": "scp-reader",
  "productName": "SCP Reader",
  "version": "1.0.0",
  "description": "Offline SCP Wiki reader built with Electron",
  "main": "main.js",
  "author": "danjon56",
  "private": true,
  "scripts": {
    "start": "electron .",
    "cache-images": "node build-image-cache.js",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.danjon56.scpreader",
    "productName": "SCP Reader",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "build-image-cache.js",
      "sigma-main/**/*",
      "package.json",
      "!dist/**/*",
      "!build/icons/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app-data",
        "filter": [
          "content_*.json",
          "image-manifest.json"
        ]
      },
      {
        "from": "image_cache",
        "to": "app-data/image_cache",
        "filter": [
          "**/*",
          "!**/*-hd.*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}